{
  "name": "packet-atlas",
  "private": true,
  "version": "17.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest --run --config vitest.config.ts",
    "capture:validate": "node scripts/captures/validate-fixtures.mjs",
    "validate:project": "node scripts/validate-project-structure.mjs",
    "atlas:health": "node scripts/atlas-health.mjs",
    "validate:all": "npm run verify",
    "bundle:budget": "node scripts/bundle-budget.mjs",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium --with-deps",
    "test:unit": "vitest --run --config vitest.config.ts",
    "test:all": "npm run test:unit && npm run e2e",
    "e2e:deps": "playwright install-deps chromium",
    "e2e:report": "playwright show-report",
    "scenario:lint": "node scripts/scenario-quality-lint.mjs",
    "atlas:quality": "npm run validate:project && npm run scenario:lint",
    "capture:export": "node scripts/captures/tshark-export.mjs",
    "capture:normalize": "node scripts/captures/normalize-fixture.mjs",
    "component:inventory": "node scripts/component-inventory.mjs",
    "hygiene:audit": "node scripts/atlas-hygiene-audit.mjs",
    "verify": "node scripts/verify-packet-atlas.mjs",
    "verify:e2e": "node scripts/verify-packet-atlas.mjs --e2e",
    "scenario:manifest:validate": "node scripts/validate-scenario-manifests.mjs",
    "capture:cross-validate": "node scripts/captures/cross-validate-scenario-fixtures.mjs",
    "visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "visual:test": "playwright test --config=playwright.visual.config.ts",
    "capture:map": "node scripts/captures/map-fixture-to-stages.mjs",
    "verify:full": "node scripts/verify-packet-atlas.mjs --full",
    "capture:doctor": "node scripts/captures/capture-environment-doctor.mjs",
    "capture:plan": "node scripts/captures/create-controlled-capture-plan.mjs",
    "capture:readiness": "node scripts/captures/fixture-readiness.mjs --allow-pending",
    "capture:readiness:strict": "node scripts/captures/fixture-readiness.mjs",
    "release:readiness": "node scripts/release-readiness.mjs",
    "capture:commands": "node scripts/captures/print-capture-commands.mjs",
    "capture:profile": "node scripts/captures/profile-pcap.mjs",
    "capture:candidate": "node scripts/captures/build-real-fixture-candidate.mjs",
    "capture:candidate:validate": "node scripts/captures/validate-real-candidate.mjs",
    "capture:candidate:promote": "node scripts/captures/validate-real-candidate.mjs --promote",
    "capture:workflow": "node scripts/captures/real-capture-workflow.mjs",
    "capture:redact": "node scripts/captures/redact-fixture.mjs",
    "capture:privacy:audit": "node scripts/captures/privacy-audit.mjs",
    "capture:privacy:audit:strict": "node scripts/captures/privacy-audit.mjs --strict",
    "capture:coverage:compare": "node scripts/captures/compare-fixture-stage-coverage.mjs",
    "capture:evidence": "node scripts/captures/build-evidence-pack.mjs",
    "v6:readiness": "node scripts/v6-readiness-gate.mjs",
    "v6:readiness:strict": "node scripts/v6-readiness-gate.mjs --strict",
    "capture:slice": "node scripts/captures/slice-clean-capture.mjs",
    "capture:registry:audit": "node scripts/captures/fixture-registry-audit.mjs",
    "capture:http-local:plan": "node scripts/captures/http-local-capture-plan.mjs",
    "visual:ci:update": "CI=1 playwright test --config=playwright.visual.config.ts --update-snapshots",
    "visual:ci:test": "CI=1 playwright test --config=playwright.visual.config.ts",
    "visual:baseline:guard": "node scripts/visual/visual-baseline-guard.mjs",
    "visual:clean": "node scripts/visual/clean-visual-artifacts.mjs",
    "capture:http-local:candidate": "node scripts/captures/build-http-local-candidate.mjs",
    "capture:http-local:validate": "node scripts/captures/validate-http-local-candidate.mjs",
    "capture:http-local:promote": "node scripts/captures/promote-http-local-candidate.mjs",
    "capture:contrast:audit": "node scripts/captures/https-http-contrast-audit.mjs",
    "project:summary": "node scripts/project/build-project-summary.mjs",
    "status:checkpoint": "npm run project:summary && npm run release:readiness",
    "contrast:workspace:audit": "node scripts/captures/contrast-workspace-audit.mjs",
    "capture:dns-failure:plan": "node scripts/captures/dns-failure-capture-plan.mjs",
    "branch:dns:readiness": "node scripts/project/dns-branch-readiness.mjs",
    "story:guided": "node scripts/project/guided-journey-script.mjs",
    "story:quality": "node scripts/project/guided-story-quality.mjs",
    "story:scenarios": "node scripts/project/guided-scenario-packs.mjs",
    "story:scenario:quality": "node scripts/project/guided-scenario-quality.mjs",
    "story:runtime": "node scripts/project/guided-scenario-runtime.mjs",
    "story:all": "node scripts/project/guided-story-all.mjs",
    "story:bridge": "node scripts/project/guided-scenario-bridge.mjs",
    "story:bridge:readiness": "node scripts/project/guided-scenario-bridge-readiness.mjs"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
